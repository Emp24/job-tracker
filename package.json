{
  "name": "job-analyzer",
  "version": "0.1.0",
  "private": true,
  "description": "Job Application Aggregator & Personal Funnel Analytics Tool",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:functions": "deno test --allow-env --no-check --config supabase/functions/deno.json supabase/functions/",
    "test:all": "pnpm test && pnpm test:functions",
    "sync:shared": "node scripts/sync-shared-schema.mjs",
    "web": "pnpm --filter @job-analyzer/web dev"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
