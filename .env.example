# Public client config — safe to expose to the browser (used by web app + extension).
# These are the "anon" values from your Supabase project (Project Settings → API).
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-public-key"

# ---------------------------------------------------------------------------
# SERVER-SIDE SECRETS — never commit real values, never expose to the client.
# The Gemini key lives ONLY as a Supabase Edge Function secret, set via:
#   supabase secrets set GEMINI_API_KEY=...
# It is listed here for documentation only; do NOT put it in a client .env.
# ---------------------------------------------------------------------------
# GEMINI_API_KEY="from Google AI Studio"
