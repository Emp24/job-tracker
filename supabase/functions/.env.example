# Local secrets for `supabase functions serve --env-file supabase/functions/.env`.
# Copy to `.env` (gitignored) and fill in. SUPABASE_URL / SUPABASE_ANON_KEY /
# SUPABASE_SERVICE_ROLE_KEY are injected automatically — do NOT set them here.

# Free key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# Optional. Override the model (defaults to "gemini-flash-lite-latest"). Pin a
# specific version here if you want reproducible behavior, e.g. gemini-3.1-flash-lite.
GEMINI_MODEL=""

# Optional. Comma-separated allowlist for CORS in production, e.g.:
# ALLOWED_ORIGINS="chrome-extension://abcdefghijklmnop,https://your-app.vercel.app"
# Leave unset locally to reflect the caller's Origin.
ALLOWED_ORIGINS=""
